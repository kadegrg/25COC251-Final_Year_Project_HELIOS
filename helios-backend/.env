# ── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
TRUST_PROXY=1

# ── Database (CockroachDB) ─────────────────────────────
DATABASE_URL=postgresql://root@localhost:26257/helios?sslmode=disable
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── JWT / Token ────────────────────────────────────────
JWT_ISSUER=helios
JWT_AUDIENCE=helios-api
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
# Base64-encoded 256-bit key for HS256 or path to PEM for RS256
JWT_SIGNING_KEY=ZqB2b9db6j0C+R7jL8rD6GwIY9zGVTJtzIPHFaDpdpc=

# ── Encryption (AES-256-GCM for TOTP secrets etc.) ────
ENCRYPTION_KEY=O/wI6I7BmchtEbeWYowmdhde8lx2iNce/Vw5ApQjfNU=

# ── Password Policy ───────────────────────────────────
PASSWORD_MIN_LENGTH=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ── TOTP ───────────────────────────────────────────────
TOTP_ISSUER=HELIOS
TOTP_ALGORITHM=sha1
TOTP_DIGITS=6
TOTP_PERIOD=30

# ── WebAuthn ───────────────────────────────────────────
WEBAUTHN_RP_NAME=HELIOS
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:5173

# ── Cookies ────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/

# ── CORS ───────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ──────────────────────────────────────
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MFA_WINDOW_MS=300000
RATE_LIMIT_MFA_MAX=5
RATE_LIMIT_API_WINDOW_MS=60000
RATE_LIMIT_API_MAX=100

# ── Site Resolution ───────────────────────────────────
SITE_RESOLUTION_MODE=hybrid
# hybrid | path | host
BASE_DOMAIN=api.helios.kadegrg.dev

